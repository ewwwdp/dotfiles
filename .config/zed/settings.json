{
  "proxy": "",
  "agent": {
    "default_profile": "ask",
    "dock": "right",
    "default_model": {
      "provider": "lmstudio",
      "model": "openai/gpt-oss-20b",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "language_models": {
    "lmstudio": {
      "api_url": "http://localhost:1234/api/v0",
    },
  },
  "cli_default_open_behavior": "existing_window",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "show_edit_predictions": false,
  "icon_theme": "Catppuccin Mocha",
  "edit_predictions": {
    "mode": "subtle",
  },
  "disable_ai": true,
  "autosave": "on_focus_change",
  "base_keymap": "VSCode",
  "ui_font_size": 15,
  "buffer_font_size": 13,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "theme": "Darker Horizon Bold",
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "auto_signature_help": true,
  "inlay_hints": {
    "enabled": true,
  },
  "restore_on_startup": "last_workspace",
  "tabs": {
    "file_icons": true,
  },
}
